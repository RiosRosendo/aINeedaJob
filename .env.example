# ============================================================
# aINeedJob — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. NEVER share this file with anyone.
# ============================================================

# ============================================================
# APP
# ============================================================
APP_ENV=development                         # development | staging | production
APP_SECRET_KEY=replace_with_random_64_char_string
APP_BASE_URL=http://localhost:3000

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/aineedjob
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================================
# AI PROVIDERS
# ============================================================
# Groq API — https://console.groq.com (free, fast inference)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# ============================================================
# JOB BOARD APIs (V1 — start here)
# ============================================================

# Adzuna — https://developer.adzuna.com
ADZUNA_APP_ID=your_app_id
ADZUNA_API_KEY=your_api_key

# The Muse — https://www.themuse.com/developers/api/v2
THEMUSE_API_KEY=your_api_key

# ============================================================
# JOB BOARD APIs (V2 — add later)
# ============================================================

# LinkedIn (requires approved partner access)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# Indeed (requires publisher account)
INDEED_PUBLISHER_ID=

# ============================================================
# EMAIL INTEGRATION (V2)
# ============================================================

# Gmail API — https://console.cloud.google.com
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Outlook / Microsoft Graph API
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
OUTLOOK_REDIRECT_URI=

# ============================================================
# SECURITY
# ============================================================
JWT_SECRET_KEY=replace_with_random_64_char_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

ENCRYPTION_KEY=replace_with_fernet_key     # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ============================================================
# REDIS (task queue)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_TO_FILE=false
